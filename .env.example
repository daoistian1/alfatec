# ALFATEC Environment Variables
# Copie este arquivo para .env.local e configure as variáveis

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://alfatec.vercel.app
NEXT_PUBLIC_SITE_NAME=ALFATEC Engenharia e Automação

# Contact Information
NEXT_PUBLIC_PHONE_PRIMARY=(24) 9999-9999
NEXT_PUBLIC_PHONE_SECONDARY=(24) 3333-3333
NEXT_PUBLIC_EMAIL_CONTACT=contato@alfatec.com.br
NEXT_PUBLIC_EMAIL_COMMERCIAL=comercial@alfatec.com.br

# Company Location
NEXT_PUBLIC_ADDRESS=Três Rios, Rio de Janeiro
NEXT_PUBLIC_WORKING_HOURS=Segunda a Sexta: 8h às 18h | Sábado: 8h às 12h

# Social Media (opcional)
NEXT_PUBLIC_INSTAGRAM=
NEXT_PUBLIC_FACEBOOK=
NEXT_PUBLIC_LINKEDIN=
NEXT_PUBLIC_WHATSAPP=5524999999999

# Google Analytics (opcional)
NEXT_PUBLIC_GA_ID=

# Google Maps API (opcional - para mapa de localização)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=